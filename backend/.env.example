# Copy to ".env" for local split-mode development (backend on :8000).
# In production (Render Docker) these are set as environment variables instead.
# Authentication has been removed, so there are no auth/OAuth settings here.

# --- Database ---
# Local dev: a MongoDB on your machine. Production: your Atlas connection string.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="timetable_genius"

# --- Optional ---
# Restrict who may call the API (only relevant in split/cross-origin dev).
# Leave "*" to allow any origin. In single-origin production it's unused.
CORS_ORIGINS="*"

# Where the built React app lives (used when serving single-origin). The Docker
# image sets this automatically; leave unset for split dev.
# FRONTEND_BUILD_DIR="../frontend/build"
