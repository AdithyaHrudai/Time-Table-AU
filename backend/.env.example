# Copy this file to ".env" and fill in real values for local development.
# In production (Render), set these as environment variables in the dashboard
# instead of committing them.

# --- Database ---
# Local dev: a MongoDB running on your machine.
# Production: your MongoDB Atlas connection string (free M0 tier).
MONGO_URL="mongodb://localhost:27017"
DB_NAME="timetable_genius"

# --- Security ---
# Long random string used to sign JWTs. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="change-me-to-a-long-random-string"

# --- CORS ---
# Local dev: "*" (any origin). Production: your frontend URL, comma-separated.
#   e.g. CORS_ORIGINS="https://your-app.vercel.app"
CORS_ORIGINS="*"

# --- Frontend URL (used to redirect back after Google login) ---
FRONTEND_URL="http://localhost:3000"

# --- Google OAuth 2.0 (free; optional) ---
# Create credentials at https://console.cloud.google.com:
#   APIs & Services > Credentials > Create OAuth client ID > Web application
#   Authorized redirect URI must match GOOGLE_REDIRECT_URI below.
# Leave GOOGLE_CLIENT_ID blank to disable Google login (email/password still works).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/google/callback"
